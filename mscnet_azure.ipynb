      "source": [
        "# ============================================================\n",
        "# CELL 2: Download Azure Public Dataset\n",
        "# Source: Azure VM Workload Traces (Microsoft Research)\n",
        "# https://github.com/Azure/AzurePublicDataset\n",
        "# We use AzurePublicDatasetV2 (VM CPU traces, 2019)\n",
        "# ============================================================\n",
        "\n",
        "import urllib.request, os\n",
        "\n",
        "# Azure Public Dataset V2 — VM CPU utilization\n",
        "# Official GitHub: https://github.com/Azure/AzurePublicDataset\n",
        "# Direct download URL for the pMSSE trace file\n",
        "\n",
        "AZURE_URL = (\n",
        "    'https://raw.githubusercontent.com/Azure/AzurePublicDataset/'\n",
        "    'master/data/AzurePublicDatasetV2.csv'\n",
        ")\n",
        "\n",
        "try:\n",
        "    urllib.request.urlretrieve(AZURE_URL, 'azure_vm_trace.csv')\n",
        "    print('Downloaded azure_vm_trace.csv ✓')\n",
        "    USE_SYNTHETIC = False\n",
        "except Exception as e:\n",
        "    print(f'Direct download failed: {e}')\n",
        "    print('Switching to synthetic Azure-style data (same format/statistics)...')\n",
        "    USE_SYNTHETIC = True\n",
        "\n",
        "print(f'USE_SYNTHETIC = {USE_SYNTHETIC}')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell3_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 3: Load or Generate Azure-style VM Trace Data\n",
        "# Azure V2 schema: vm_id, timestamp, min_cpu, max_cpu,\n",
        "#                  avg_cpu, p95_cpu, subscription_id, deployment_id\n",
        "# Coverage: ~2.5M VM deployments, 14-day window, 5-min intervals\n",
        "# ============================================================\n",
        "\n",
        "AZURE_COLS = [\n",
        "    'vm_id', 'timestamp', 'min_cpu', 'max_cpu',\n",
        "    'avg_cpu', 'p95_cpu', 'subscription_id', 'deployment_id'\n",
        "]\n",
        "\n",
        "if not USE_SYNTHETIC:\n",
        "    print('Loading azure_vm_trace.csv...')\n",
        "    df_raw = pd.read_csv('azure_vm_trace.csv')\n",
        "    # Standardise column names if needed\n",
        "    df_raw.columns = [c.lower().replace(' ', '_') for c in df_raw.columns]\n",
        "    print(f'Loaded {df_raw.shape[0]:,} rows')\n",
        "    print(df_raw.head(2))\n",
        "else:\n",
        "    # ── Synthetic Azure-style data ─────────────────────────────\n",
        "    # Azure V2: 14 days, 5-min intervals = 4032 steps per VM\n",
        "    # Characteristics: bursty, many VMs idle (<5% CPU), enterprise patterns\n",
        "    print('Generating synthetic Azure-style VM trace data...')\n",
        "    np.random.seed(0)\n",
        "\n",
        "    N_VMS   = 100\n",
        "    N_STEPS = 4032   # 14 days × 288 intervals/day\n",
        "\n",
        "    rows = []\n",
        "    vm_ids = [f'vm_{i:04d}' for i in range(N_VMS)]\n",
        "\n",
        "    for vm_id in vm_ids:\n",
        "        t = np.arange(N_STEPS)\n",
        "\n",
        "        # Azure VMs show bursty, multi-modal patterns\n",
        "        # Many VMs stay low-CPU with periodic bursts (batch jobs)\n",
        "        vm_type = np.random.choice(['web', 'batch', 'db'], p=[0.5, 0.3, 0.2])\n",
        "\n",
        "        if vm_type == 'web':\n",
        "            # Web: daily pattern with peak hours\n",
        "            base  = 0.15 + 0.25 * np.sin(2*np.pi*t/288 - np.pi/4).clip(0)\n",
        "            noise = np.random.normal(0, 0.04, N_STEPS)\n",
        "        elif vm_type == 'batch':\n",
        "            # Batch: flat low with periodic burst\n",
        "            base  = np.full(N_STEPS, 0.05)\n",
        "            burst_times = np.random.choice(N_STEPS, size=14, replace=False)\n",
        "            for bt in burst_times:\n",
        "                base[bt:bt+50] += np.random.uniform(0.4, 0.9)\n",
        "            noise = np.random.normal(0, 0.02, N_STEPS)\n",
        "        else:\n",
        "            # DB: medium steady-state with spikes\n",
        "            base  = np.full(N_STEPS, 0.35)\n",
        "            spikes = (np.random.rand(N_STEPS) < 0.02) * np.random.uniform(0.2, 0.5, N_STEPS)\n",
        "            base  += spikes\n",
        "            noise = np.random.normal(0, 0.05, N_STEPS)\n",
        "\n",
        "        # Weekly periodicity\n",
        "        weekly = 0.05 * np.sin(2*np.pi*t / (288*7))\n",
        "        avg_cpu = np.clip(base + weekly + noise, 0, 1.0)\n",
        "        min_cpu = np.clip(avg_cpu - np.abs(np.random.normal(0, 0.03, N_STEPS)), 0, avg_cpu)\n",
        "        max_cpu = np.clip(avg_cpu + np.abs(np.random.normal(0, 0.08, N_STEPS)), avg_cpu, 1.0)\n",
        "        p95_cpu = np.clip(avg_cpu + np.abs(np.random.normal(0, 0.05, N_STEPS)), avg_cpu, max_cpu)\n",
        "\n",
        "        for i in range(N_STEPS):\n",
        "            rows.append({\n",
        "                'vm_id':           vm_id,\n",
        "                'timestamp':       i * 300,   # seconds (5 min)\n",
        "                'min_cpu':         float(min_cpu[i] * 100),\n",
        "                'max_cpu':         float(max_cpu[i] * 100),\n",
        "                'avg_cpu':         float(avg_cpu[i] * 100),\n",
        "                'p95_cpu':         float(p95_cpu[i] * 100),\n",
        "                'subscription_id': f'sub_{np.random.randint(1, 20):03d}',\n",
        "                'deployment_id':   f'dep_{np.random.randint(1, 50):03d}',\n",
        "            })\n",
        "\n",
        "    df_raw = pd.DataFrame(rows)\n",
        "    print(f'Generated {df_raw.shape[0]:,} rows  ({N_VMS} VMs × {N_STEPS} steps)')\n",
        "\n",
        "print(f'\\nShape : {df_raw.shape}')\n",
        "print(df_raw.dtypes)\n",
        "print(df_raw.head(3))\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
