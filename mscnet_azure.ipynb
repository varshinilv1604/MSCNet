      "source": [
        "# ============================================================\n",
        "# CELL 4: Data Exploration\n",
        "# ============================================================\n",
        "\n",
        "cpu_col = 'avg_cpu'\n",
        "\n",
        "print('=== BASIC STATISTICS ===')\n",
        "print(df_raw[['min_cpu', 'avg_cpu', 'max_cpu', 'p95_cpu']].describe())\n",
        "\n",
        "print('\\n=== MISSING VALUES ===')\n",
        "print(df_raw.isnull().sum())\n",
        "\n",
        "print(f'\\n=== KEY FACTS ===')\n",
        "print(f'Unique VMs      : {df_raw[\"vm_id\"].nunique():,}')\n",
        "print(f'Time range      : {df_raw[\"timestamp\"].min()} → {df_raw[\"timestamp\"].max()} seconds')\n",
        "print(f'Avg CPU range   : {df_raw[cpu_col].min():.2f}% → {df_raw[cpu_col].max():.2f}%')\n",
        "days_covered = (df_raw['timestamp'].max() - df_raw['timestamp'].min()) / 86400\n",
        "print(f'Coverage        : {days_covered:.1f} days')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell5_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 5: Preprocessing Step 1 — Clean & Filter\n",
        "# Azure: 100 VMs selected, fill NaN, sort by time\n",
        "# ============================================================\n",
        "\n",
        "print('=== PREPROCESSING STEP 1: Clean ===\\n')\n",
        "\n",
        "# Fill missing avg_cpu values\n",
        "n_missing = df_raw['avg_cpu'].isnull().sum()\n",
        "if n_missing > 0:\n",
        "    df_raw['avg_cpu'].fillna(df_raw['avg_cpu'].median(), inplace=True)\n",
        "    print(f'  Filled {n_missing:,} missing in \"avg_cpu\"')\n",
        "\n",
        "# Sort by vm_id and timestamp\n",
        "df_raw = df_raw.sort_values(['vm_id', 'timestamp']).reset_index(drop=True)\n",
        "print('  Sorted by vm_id, timestamp ✓')\n",
        "\n",
        "# Select top 100 VMs by data volume\n",
        "top_vms = (\n",
        "    df_raw.groupby('vm_id').size()\n",
        "    .nlargest(100).index.tolist()\n",
        ")\n",
        "df_100 = df_raw[df_raw['vm_id'].isin(top_vms)].copy()\n",
        "\n",
        "print(f'  Selected top 100 VMs')\n",
        "print(f'  Rows after selection : {df_100.shape[0]:,}')\n",
        "print(f'  VMs confirmed        : {df_100[\"vm_id\"].nunique()}')\n",
        "print('\\nStep 1 Complete ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell6_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 6: Preprocessing Step 2 — Build Time Series Matrix\n",
        "# Azure: 14 days at 5-min intervals = 4032 timesteps\n",
        "# ============================================================\n",
        "\n",
        "print('=== PREPROCESSING STEP 2: Build Time Series ===\\n')\n",
        "\n",
        "# 5-min bins (Azure native resolution is already 5 min)\n",
        "INTERVAL_SEC = 300   # 5 minutes\n",
        "N_DAYS       = 14\n",
        "N_BUCKETS    = N_DAYS * 24 * 12   # 14 × 288 = 4032 bins\n",
        "\n",
        "print(f'  Interval       : {INTERVAL_SEC}s (5 min)')\n",
        "print(f'  Total buckets  : {N_BUCKETS}  ({N_DAYS} days × 288 intervals/day)')\n",
        "\n",
        "df_100 = df_100.copy()\n",
        "df_100['time_bin'] = (df_100['timestamp'] // INTERVAL_SEC).astype(int)\n",
        "df_100['time_bin'] = df_100['time_bin'].clip(0, N_BUCKETS - 1)\n",
        "\n",
        "# Aggregate avg_cpu per VM per bin\n",
        "print('  Aggregating avg CPU utilization...')\n",
        "cpu_agg = (\n",
        "    df_100\n",
        "    .groupby(['vm_id', 'time_bin'])['avg_cpu']\n",
        "    .mean()\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "# Pivot → (VMs × time) matrix\n",
        "print('  Building matrix...')\n",
        "cpu_pivot = (\n",
        "    cpu_agg\n",
        "    .pivot(index='vm_id', columns='time_bin', values='avg_cpu')\n",
        "    .ffill(axis=1)\n",
        "    .fillna(0)\n",
        "    .reindex(columns=range(N_BUCKETS), fill_value=0)\n",
        ")\n",
        "\n",
        "cpu_matrix    = cpu_pivot.values.astype(np.float32)\n",
        "top_100_vms   = list(cpu_pivot.index)\n",
        "\n",
        "print(f'\\n  Matrix shape     : {cpu_matrix.shape}  (VMs × time_steps)')\n",
        "print(f'  Non-zero entries : {(cpu_matrix > 0).sum():,} / {cpu_matrix.size:,}'\n",
        "      f'  ({100*(cpu_matrix > 0).mean():.1f}%)')\n",
        "print('\\nStep 2 Complete ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell7_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 7: Preprocessing Step 3 — Per-VM Min-Max Scale\n",
        "# Azure VMs: many low-utilization (<10%), bursty patterns\n",
        "# ============================================================\n",
        "\n",
        "print('=== PREPROCESSING STEP 3: Scale ===\\n')\n",
        "\n",
        "cpu_scaled = np.zeros_like(cpu_matrix)\n",
        "\n",
        "for i in range(cpu_matrix.shape[0]):\n",
        "    row = cpu_matrix[i]\n",
        "    mn  = row.min()\n",
        "    mx  = row.max()\n",
        "    if mx - mn > 1e-10:\n",
        "        cpu_scaled[i] = (row - mn) / (mx - mn)\n",
        "    else:\n",
        "        cpu_scaled[i] = row\n",
        "\n",
        "# Remove VMs with all zeros\n",
        "valid_mask = cpu_scaled.max(axis=1) > 0.01\n",
        "cpu_scaled = cpu_scaled[valid_mask]\n",
        "print(f'  Valid VMs (non-zero) : {cpu_scaled.shape[0]}')\n",
        "\n",
        "cpu_nz = cpu_scaled[cpu_scaled > 0]\n",
        "print(f'  CPU mean (nonzero) : {cpu_nz.mean():.4f}')\n",
        "print(f'  CPU std            : {cpu_nz.std():.4f}')\n",
        "print(f'  CPU min            : {cpu_scaled.min():.4f}')\n",
        "print(f'  CPU max            : {cpu_scaled.max():.4f}')\n",
        "\n",
        "under = (cpu_nz < 0.20).mean() * 100\n",
        "over  = (cpu_nz > 0.80).mean() * 100\n",
        "norm  = 100 - under - over\n",
        "print(f'\\n  Under-utilized (<20%) : {under:.1f}%')\n",
        "print(f'  Normal (20%-80%)      : {norm:.1f}%')\n",
        "print(f'  Over-utilized  (>80%) : {over:.1f}%')\n",
        "print('\\nStep 3 Complete ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
