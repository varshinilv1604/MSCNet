        "# ============================================================\n",
        "# CELL 9: RevIN — Reversible Instance Normalization\n",
        "# Equation (1)-(3) from MSCNet paper\n",
        "# ============================================================\n",
        "\n",
        "class RevIN(nn.Module):\n",
        "    def __init__(self, num_features, eps=1e-5, affine=True):\n",
        "        super().__init__()\n",
        "        self.eps     = eps\n",
        "        self.affine  = affine\n",
        "        if affine:\n",
        "            self.gamma = nn.Parameter(torch.ones(num_features))\n",
        "            self.beta  = nn.Parameter(torch.zeros(num_features))\n",
        "\n",
        "    def forward(self, x, mode):\n",
        "        if mode == 'norm':\n",
        "            self.mean = x.mean(dim=1, keepdim=True)\n",
        "            self.std  = x.std( dim=1, keepdim=True) + self.eps\n",
        "            x = (x - self.mean) / self.std\n",
        "            if self.affine:\n",
        "                x = x * self.gamma + self.beta\n",
        "        elif mode == 'denorm':\n",
        "            if self.affine:\n",
        "                x = (x - self.beta) / (self.gamma + self.eps)\n",
        "            x = x * self.std + self.mean\n",
        "        return x\n",
        "\n",
        "revin_test = RevIN(num_features=1)\n",
        "x_test     = torch.randn(4, 96, 1)\n",
        "x_norm     = revin_test(x_test, 'norm')\n",
        "x_back     = revin_test(x_norm, 'denorm')\n",
        "print(f'RevIN: {x_test.shape} → norm → denorm → {x_back.shape}')\n",
        "print(f'  Reconstruction error : {(x_test - x_back).abs().max():.2e}  ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell10_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 10: Trend Prediction Block — Equation (4)\n",
        "# ============================================================\n",
        "\n",
        "class TrendPredictionBlock(nn.Module):\n",
        "    def __init__(self, input_len=96, pred_len=24, kernel_size=48):\n",
        "        super().__init__()\n",
        "        self.pool   = nn.AvgPool1d(kernel_size=kernel_size, stride=1, padding=kernel_size // 2)\n",
        "        pool_out    = input_len + (1 if kernel_size % 2 == 0 else 0)\n",
        "        self.linear = nn.Linear(pool_out, pred_len)\n",
        "\n",
        "    def forward(self, x):\n",
        "        x_t   = self.pool(x.permute(0, 2, 1))\n",
        "        x_t   = x_t[:, :, :x.shape[1] + 1]\n",
        "        trend = self.linear(x_t).permute(0, 2, 1)\n",
        "        return trend\n",
        "\n",
        "tb = TrendPredictionBlock(96, 24, 48)\n",
        "xt = torch.randn(4, 96, 1)\n",
        "print(f'TrendBlock: {xt.shape} → {tb(xt).shape}  ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell11_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 11: Multi-Scale Patch Block — Equation (5)\n",
        "# ============================================================\n",
        "\n",
        "class MultiScalePatchBlock(nn.Module):\n",
        "    def __init__(self, input_len=96, d_model=128, patch_sizes=[4, 8, 16, 32, 48]):\n",
        "        super().__init__()\n",
        "        self.patch_sizes = patch_sizes\n",
        "        self.n_patches   = [input_len // ps for ps in patch_sizes]\n",
        "        self.linears     = nn.ModuleList([nn.Linear(ps, d_model) for ps in patch_sizes])\n",
        "        self.total_out   = sum(n * d_model for n in self.n_patches)\n",
        "\n",
        "    def forward(self, x):\n",
        "        B   = x.shape[0]\n",
        "        xf  = x.squeeze(-1)\n",
        "        outputs = []\n",
        "        for ps, linear, n_p in zip(self.patch_sizes, self.linears, self.n_patches):\n",
        "            patches = []\n",
        "            for k in range(n_p):\n",
        "                p = xf[:, k*ps:(k+1)*ps]\n",
        "                if p.shape[-1] < ps:\n",
        "                    p = F.pad(p, (0, ps - p.shape[-1]))\n",
        "                patches.append(p)\n",
        "            x_p   = torch.stack(patches, dim=1)\n",
        "            x_map = linear(x_p)\n",
        "            outputs.append(x_map.reshape(B, -1))\n",
        "        return torch.cat(outputs, dim=-1)\n",
        "\n",
        "mb = MultiScalePatchBlock(96, 128)\n",
        "xt = torch.randn(4, 96, 1)\n",
        "xe = mb(xt)\n",
        "print(f'MultiScalePatch: {xt.shape} → {xe.shape}  ✓')\n",
        "print(f'  5 scales: {mb.n_patches} patches each')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell12_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 12: Transformer Encoder — Equation (6)\n",
        "# ============================================================\n",
        "\n",
        "class TransformerEncoderBlock(nn.Module):\n",
        "    def __init__(self, d_model=128, nhead=8, dim_ff=256, dropout=0.2):\n",
        "        super().__init__()\n",
        "        enc = nn.TransformerEncoderLayer(\n",
        "            d_model=d_model, nhead=nhead, dim_feedforward=dim_ff,\n",
        "            dropout=dropout, batch_first=True\n",
        "        )\n",
        "        self.transformer = nn.TransformerEncoder(enc, num_layers=1)\n",
        "        self.norm        = nn.BatchNorm1d(d_model)\n",
        "\n",
        "    def forward(self, x):\n",
        "        out = self.transformer(x)\n",
        "        out = self.norm(out.permute(0, 2, 1)).permute(0, 2, 1)\n",
        "        return out\n",
        "\n",
        "te = TransformerEncoderBlock()\n",
        "xt = torch.randn(4, 5, 128)\n",
        "print(f'TransformerEncoder: {xt.shape} → {te(xt).shape}  ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell13_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 13: Multi-Scale Conv Block — Equation (7)\n",
        "# ============================================================\n",
        "\n",
        "class MultiScaleConvBlock(nn.Module):\n",
        "    def __init__(self, in_ch, out_ch, kernel_c=3):\n",
        "        super().__init__()\n",
        "        kc  = kernel_c\n",
        "        kc2 = max(1, kc // 2)\n",
        "        self.equi   = nn.Conv1d(in_ch, out_ch, kernel_size=kc, padding=kc//2, stride=1)\n",
        "        self.sparse = nn.Conv1d(in_ch + out_ch, out_ch, kernel_size=kc, padding=kc2, stride=kc2)\n",
        "        self.dense  = nn.Conv1d(out_ch + out_ch, out_ch, kernel_size=kc2, padding=0, stride=kc2)\n",
        "        self.bn1    = nn.BatchNorm1d(out_ch)\n",
        "        self.bn2    = nn.BatchNorm1d(out_ch)\n",
        "        self.bn3    = nn.BatchNorm1d(out_ch)\n",
        "\n",
        "    def forward(self, x):\n",
        "        x_equi   = F.relu(self.bn1(self.equi(x)))\n",
        "        L1       = min(x.shape[-1], x_equi.shape[-1])\n",
        "        x_cat1   = torch.cat([x[:, :, :L1], x_equi[:, :, :L1]], dim=1)\n",
        "        x_sparse = F.relu(self.bn2(self.sparse(x_cat1)))\n",
        "        L2       = min(x_equi.shape[-1], x_sparse.shape[-1])\n",
        "        x_cat2   = torch.cat([x_equi[:, :, :L2], x_sparse[:, :, :L2]], dim=1)\n",
        "        x_dense  = F.relu(self.bn3(self.dense(x_cat2)))\n",
        "        L3       = min(x_sparse.shape[-1], x_dense.shape[-1])\n",
        "        return torch.cat([x_sparse[:, :, :L3], x_dense[:, :, :L3]], dim=1)\n",
        "\n",
        "cb  = MultiScaleConvBlock(in_ch=128, out_ch=64, kernel_c=3)\n",
        "xt  = torch.randn(4, 128, 5)\n",
        "out = cb(xt)\n",
        "print(f'MultiScaleConvBlock: {xt.shape} → {out.shape}  ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell14_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 14: Full MSCNet\n",
        "# Table II params: L=96, d=128, N=3, S=5, dropout=0.2\n",
        "# ============================================================\n",
        "\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "\n",
        "class MSCNet(nn.Module):\n",
        "    \"\"\"\n",
        "    MSCNet — Zhao et al. IEEE TSC 2025\n",
        "    Table II params: L=96, d=128, N=3, S=5, dropout=0.2\n",
        "    \"\"\"\n",
        "    def __init__(self, input_len=96, pred_len=24,\n",
        "                 d_model=128, n_heads=8, N=3, S=5,\n",
        "                 patch_sizes=[4, 8, 16, 32, 48], dropout=0.2):\n",
        "        super().__init__()\n",
        "        self.pred_len   = pred_len\n",
        "        self.d_model    = d_model\n",
        "        self.num_scales = S\n",
        "        half            = d_model // 2\n",
        "        self.revin      = RevIN(num_features=1)\n",
        "        self.trend      = TrendPredictionBlock(input_len, pred_len, patch_sizes[-1])\n",
        "        self.mspb       = MultiScalePatchBlock(input_len, d_model, patch_sizes[:S])\n",
        "        self.patch_proj = nn.Linear(self.mspb.total_out, S * d_model)\n",
        "        self.t_blocks   = nn.ModuleList([\n",
        "            TransformerEncoderBlock(d_model, n_heads, d_model * 2, dropout) for _ in range(N)\n",
        "        ])\n",
        "        self.c_blocks   = nn.ModuleList([\n",
        "            MultiScaleConvBlock(in_ch=d_model, out_ch=half, kernel_c=3) for _ in range(N)\n",
        "        ])\n",
        "        self.b_linears  = nn.ModuleList([nn.Linear(d_model, d_model) for _ in range(N)])\n",
        "        self.b_norms    = nn.ModuleList([nn.LayerNorm(d_model) for _ in range(N)])\n",
        "        self.out_linear = nn.Linear(S * d_model, pred_len)\n",
        "\n",
        "    def forward(self, x):\n",
        "        B  = x.shape[0]\n",
        "        Xr = self.revin(x, 'norm')\n",
        "        Yt = self.trend(Xr)\n",
        "        h  = self.patch_proj(self.mspb(Xr))\n",
        "        h  = h.reshape(B, self.num_scales, self.d_model)\n",
        "        for i in range(len(self.t_blocks)):\n",
        "            h   = self.t_blocks[i](h)\n",
        "            h_c = self.c_blocks[i](h.permute(0, 2, 1))\n",
        "            h_back = h_c.permute(0, 2, 1)\n",
        "            if h_back.shape[1] != self.num_scales:\n",
        "                h_back = F.interpolate(\n",
        "                    h_back.permute(0, 2, 1),\n",
        "                    size=self.num_scales, mode='linear', align_corners=False\n",
        "                ).permute(0, 2, 1)\n",
        "            h = self.b_norms[i](self.b_linears[i](h_back))\n",
        "        Ym = self.out_linear(h.reshape(B, -1)).unsqueeze(-1)\n",
        "        return self.revin(Yt + Ym, 'denorm')\n",
        "\n",
        "model = MSCNet(input_len=96, pred_len=24).to(device)\n",
        "x_t   = torch.randn(4, 96, 1).to(device)\n",
        "y_t   = model(x_t)\n",
        "total = sum(p.numel() for p in model.parameters())\n",
        "print('=' * 40)\n",
        "print(f'Input  : {x_t.shape}')\n",
        "print(f'Output : {y_t.shape}')\n",
        "print(f'Params : {total:,}')\n",
        "print('=' * 40)\n",
        "print('MSCNet ✓ — no errors!')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell15_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 15: Dataset and DataLoader\n",
        "# Paper: L=96, H=24, 7:1:2 split, batch=32\n",
        "# ============================================================\n",
        "\n",
        "class CloudDataset(torch.utils.data.Dataset):\n",
        "    def __init__(self, series, input_len=96, pred_len=24):\n",
        "        self.data      = torch.FloatTensor(series)\n",
        "        self.input_len = input_len\n",
        "        self.pred_len  = pred_len\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.data) - self.input_len - self.pred_len + 1\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        x = self.data[idx : idx+self.input_len]\n",
        "        y = self.data[idx+self.input_len : idx+self.input_len+self.pred_len]\n",
        "        return x.unsqueeze(-1), y.unsqueeze(-1)\n",
        "\n",
        "\n",
        "def get_loaders(series, input_len=96, pred_len=24, batch_size=32):\n",
        "    n       = len(series)\n",
        "    tr_end  = int(n * 0.7)\n",
        "    val_end = int(n * 0.8)\n",
        "    tr  = CloudDataset(series[:tr_end], input_len, pred_len)\n",
        "    val = CloudDataset(series[tr_end:val_end], input_len, pred_len)\n",
        "    te  = CloudDataset(series[val_end:], input_len, pred_len)\n",
        "    tr_dl  = torch.utils.data.DataLoader(tr,  batch_size=batch_size, shuffle=True,  drop_last=True)\n",
        "    val_dl = torch.utils.data.DataLoader(val, batch_size=batch_size, shuffle=False, drop_last=True)\n",
        "    te_dl  = torch.utils.data.DataLoader(te,  batch_size=batch_size, shuffle=False, drop_last=True)\n",
        "    return tr_dl, val_dl, te_dl\n",
        "\n",
        "\n",
        "series = cpu_scaled[0]\n",
        "tr_dl, val_dl, te_dl = get_loaders(series, input_len=96, pred_len=24, batch_size=32)\n",
        "\n",
        "xb, yb = next(iter(tr_dl))\n",
        "print(f'Batch X : {xb.shape}  (batch, lookback, 1)')\n",
        "print(f'Batch Y : {yb.shape}  (batch, horizon, 1)')\n",
        "print(f'Train   : {len(tr_dl.dataset):,} samples')\n",
        "print(f'Val     : {len(val_dl.dataset):,} samples')\n",
        "print(f'Test    : {len(te_dl.dataset):,} samples')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell16_azure"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 16: Training — exact paper config (Table II)\n",
        "# LR=1e-4, decay=0.5, patience=3, MSE loss, Adam\n",
        "# ============================================================\n",
        "\n",
        "def train_mscnet(model, tr_dl, val_dl, epochs=30, lr=1e-4):\n",
        "    opt       = torch.optim.Adam(model.parameters(), lr=lr)\n",
        "    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n",
        "        opt, mode='min', factor=0.5, patience=3, verbose=True\n",
        "    )\n",
        "    criterion = nn.MSELoss()\n",
        "    history   = {'train_loss': [], 'val_loss': []}\n",
        "    best_val  = float('inf')\n",
        "\n",
        "    for epoch in range(epochs):\n",
        "        model.train()\n",
        "        tr_losses = []\n",
        "        for xb, yb in tr_dl:\n",
        "            xb, yb = xb.to(device), yb.to(device)\n",
        "            opt.zero_grad()\n",
        "            pred = model(xb)\n",
        "            loss = criterion(pred, yb)\n",
        "            loss.backward()\n",
        "            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
        "            opt.step()\n",
        "            tr_losses.append(loss.item())\n",
        "\n",
        "        model.eval()\n",
        "        val_losses = []\n",
        "        with torch.no_grad():\n",
        "            for xb, yb in val_dl:\n",
        "                xb, yb = xb.to(device), yb.to(device)\n",
        "                val_losses.append(criterion(model(xb), yb).item())\n",
        "\n",
        "        tr_loss  = np.mean(tr_losses)\n",
        "        val_loss = np.mean(val_losses)\n",
        "        history['train_loss'].append(tr_loss)\n",
        "        history['val_loss'].append(val_loss)\n",
        "        scheduler.step(val_loss)\n",
        "\n",
        "        if val_loss < best_val:\n",
        "            best_val = val_loss\n",
        "            torch.save(model.state_dict(), 'best_mscnet_azure.pt')\n",
        "\n",
        "        if (epoch + 1) % 5 == 0:\n",
        "            print(f'Epoch {epoch+1:3d}/{epochs}  '\n",
        "                  f'Train={tr_loss:.6f}  Val={val_loss:.6f}  '\n",
        "                  f'Best={best_val:.6f}')\n",
        "\n",
        "    return history\n",
        "\n",
        "\n",
        "model = MSCNet(input_len=96, pred_len=24).to(device)\n",
        "print(f'Training on: {device}')\n",
        "history = train_mscnet(model, tr_dl, val_dl, epochs=30, lr=1e-4)\n",
        "print('\\nTraining complete ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
