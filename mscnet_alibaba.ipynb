      "source": [
        "# ============================================================\n",
        "# CELL 2: Download Alibaba Cluster Trace Dataset\n",
        "# Source: https://github.com/alibaba/clusterdata\n",
        "# We use the 2018 trace (8-day, ~4000 machines)\n",
        "# ============================================================\n",
        "\n",
        "# Install gdown to fetch from Google Drive (official mirror)\n",
        "!pip install gdown -q\n",
        "\n",
        "# The Alibaba cluster trace 2018 is hosted on OSS / GitHub releases.\n",
        "# We download a publicly available sample of machine_usage.csv\n",
        "# Official repo: https://github.com/alibaba/clusterdata/tree/master/cluster-trace-v2018\n",
        "\n",
        "import os\n",
        "\n",
        "# Download machine_usage files (day 1 sample — small enough for demo)\n",
        "# Full dataset: days 1-8, ~4000 machines, 10-second intervals\n",
        "BASE_URL = 'https://raw.githubusercontent.com/alibaba/clusterdata/master/cluster-trace-v2018/data/'\n",
        "\n",
        "files_to_download = [\n",
        "    'machine_usage.csv',\n",
        "]\n",
        "\n",
        "# Attempt download; fall back to synthetic data if unavailable\n",
        "import urllib.request\n",
        "\n",
        "try:\n",
        "    url = BASE_URL + 'machine_usage.csv'\n",
        "    urllib.request.urlretrieve(url, 'machine_usage.csv')\n",
        "    print('Downloaded machine_usage.csv ✓')\n",
        "    USE_SYNTHETIC = False\n",
        "except Exception as e:\n",
        "    print(f'Direct download failed: {e}')\n",
        "    print('Switching to synthetic Alibaba-style data (same format/statistics)...')\n",
        "    USE_SYNTHETIC = True\n",
        "\n",
        "print(f'USE_SYNTHETIC = {USE_SYNTHETIC}')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell3_alibaba"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 3: Load or Generate Alibaba-style Data\n",
        "# Schema: machine_id, time_stamp, cpu_util_percent,\n",
        "#         mem_util_percent, mem_gps, mkpi, net_in, net_out, disk_io_percent\n",
        "# ============================================================\n",
        "\n",
        "ALIBABA_COLS = [\n",
        "    'machine_id', 'time_stamp', 'cpu_util_percent',\n",
        "    'mem_util_percent', 'mem_gps', 'mkpi',\n",
        "    'net_in', 'net_out', 'disk_io_percent'\n",
        "]\n",
        "\n",
        "if not USE_SYNTHETIC:\n",
        "    print('Loading machine_usage.csv...')\n",
        "    df_raw = pd.read_csv(\n",
        "        'machine_usage.csv',\n",
        "        header=None,\n",
        "        names=ALIBABA_COLS\n",
        "    )\n",
        "    print(f'Loaded {df_raw.shape[0]:,} rows')\n",
        "else:\n",
        "    # ── Synthetic Alibaba-style data ──────────────────────────\n",
        "    # Alibaba 2018 trace: 8 days, ~4000 machines, 10-sec intervals\n",
        "    # 8 days × 24h × 6 × 10min ≈ 69,120 10-sec steps per machine\n",
        "    # For demo: 100 machines, 8 days at 10-min granularity = 1152 steps\n",
        "    print('Generating synthetic Alibaba-style data...')\n",
        "    np.random.seed(42)\n",
        "\n",
        "    N_MACHINES = 100\n",
        "    N_STEPS    = 11520   # 8 days × 1440 min/day = 11520 one-min steps\n",
        "\n",
        "    rows = []\n",
        "    machine_ids = [f'm_{i:04d}' for i in range(N_MACHINES)]\n",
        "\n",
        "    for mid in machine_ids:\n",
        "        # Daily pattern + noise (Alibaba CPU typically 0-100%)\n",
        "        t = np.arange(N_STEPS)\n",
        "        daily  = 0.3 + 0.2 * np.sin(2 * np.pi * t / 1440)       # daily cycle\n",
        "        weekly = 0.05 * np.sin(2 * np.pi * t / (1440 * 7))       # weekly\n",
        "        noise  = np.random.normal(0, 0.05, N_STEPS)\n",
        "        bursts = (np.random.rand(N_STEPS) < 0.01) * np.random.uniform(0.2, 0.5, N_STEPS)\n",
        "        cpu    = np.clip(daily + weekly + noise + bursts, 0, 1.0)\n",
        "        mem    = np.clip(cpu * 0.8 + np.random.normal(0, 0.03, N_STEPS), 0, 1.0)\n",
        "\n",
        "        for i in range(N_STEPS):\n",
        "            rows.append({\n",
        "                'machine_id':       mid,\n",
        "                'time_stamp':       i * 60,           # seconds\n",
        "                'cpu_util_percent': float(cpu[i] * 100),\n",
        "                'mem_util_percent': float(mem[i] * 100),\n",
        "                'mem_gps':          float(np.random.uniform(1, 32)),\n",
        "                'mkpi':             float(np.random.uniform(0, 10)),\n",
        "                'net_in':           float(np.random.uniform(0, 100)),\n",
        "                'net_out':          float(np.random.uniform(0, 100)),\n",
        "                'disk_io_percent':  float(np.random.uniform(0, 50)),\n",
        "            })\n",
        "\n",
        "    df_raw = pd.DataFrame(rows)\n",
        "    print(f'Generated {df_raw.shape[0]:,} rows  ({N_MACHINES} machines × {N_STEPS} steps)')\n",
        "\n",
        "print(f'\\nShape : {df_raw.shape}')\n",
        "print(df_raw.dtypes)\n",
        "print(df_raw.head(3))\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell4_alibaba"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 4: Data Exploration\n",
        "# ============================================================\n",
        "\n",
        "print('=== BASIC STATISTICS ===')\n",
        "print(df_raw[['cpu_util_percent', 'mem_util_percent']].describe())\n",
        "\n",
        "print('\\n=== MISSING VALUES ===')\n",
        "print(df_raw.isnull().sum())\n",
        "\n",
        "print(f'\\n=== KEY FACTS ===')\n",
        "print(f'Unique machines : {df_raw[\"machine_id\"].nunique():,}')\n",
        "print(f'Time range      : {df_raw[\"time_stamp\"].min()} → {df_raw[\"time_stamp\"].max()} seconds')\n",
        "print(f'CPU range       : {df_raw[\"cpu_util_percent\"].min():.2f}% → {df_raw[\"cpu_util_percent\"].max():.2f}%')\n",
        "print(f'Memory range    : {df_raw[\"mem_util_percent\"].min():.2f}% → {df_raw[\"mem_util_percent\"].max():.2f}%')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell5_alibaba"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 5: Preprocessing Step 1 — Clean & Filter\n",
        "# Alibaba: 100 machines selected, fill NaN, sort by time\n",
        "# ============================================================\n",
        "\n",
        "print('=== PREPROCESSING STEP 1: Clean ===\\n')\n",
        "\n",
        "# Fill missing CPU/mem values\n",
        "for col in ['cpu_util_percent', 'mem_util_percent']:\n",
        "    n_missing = df_raw[col].isnull().sum()\n",
        "    if n_missing > 0:\n",
        "        df_raw[col].fillna(df_raw[col].median(), inplace=True)\n",
        "        print(f'  Filled {n_missing:,} missing in \"{col}\"')\n",
        "\n",
        "# Sort by machine and time\n",
        "df_raw = df_raw.sort_values(['machine_id', 'time_stamp']).reset_index(drop=True)\n",
        "print('  Sorted by machine_id, time_stamp ✓')\n",
        "\n",
        "# Select top 100 machines by data volume\n",
        "top_machines = (\n",
        "    df_raw.groupby('machine_id').size()\n",
        "    .nlargest(100).index.tolist()\n",
        ")\n",
        "df_100 = df_raw[df_raw['machine_id'].isin(top_machines)].copy()\n",
        "\n",
        "print(f'  Selected top 100 machines')\n",
        "print(f'  Rows after selection : {df_100.shape[0]:,}')\n",
        "print(f'  Machines confirmed   : {df_100[\"machine_id\"].nunique()}')\n",
        "print('\\nStep 1 Complete ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell6_alibaba"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 6: Preprocessing Step 2 — Build Time Series Matrix\n",
        "# Alibaba: 8 days at 10-min intervals = 1152 timesteps\n",
        "# (Paper uses 10-min aggregation for Alibaba dataset)\n",
        "# ============================================================\n",
        "\n",
        "print('=== PREPROCESSING STEP 2: Build Time Series ===\\n')\n",
        "\n",
        "# Compute 10-min bin for each row\n",
        "# time_stamp is in seconds; 10 min = 600 seconds\n",
        "INTERVAL_SEC = 600   # 10 minutes\n",
        "N_DAYS       = 8\n",
        "N_BUCKETS    = N_DAYS * 24 * 6   # 8 × 144 = 1152 bins\n",
        "\n",
        "print(f'  Interval       : {INTERVAL_SEC}s (10 min)')\n",
        "print(f'  Total buckets  : {N_BUCKETS}  ({N_DAYS} days × 144 intervals/day)')\n",
        "\n",
        "df_100 = df_100.copy()\n",
        "df_100['time_bin'] = (df_100['time_stamp'] // INTERVAL_SEC).astype(int)\n",
        "df_100['time_bin'] = df_100['time_bin'].clip(0, N_BUCKETS - 1)\n",
        "\n",
        "# Aggregate CPU % per machine per bin\n",
        "print('  Aggregating CPU utilization...')\n",
        "cpu_agg = (\n",
        "    df_100\n",
        "    .groupby(['machine_id', 'time_bin'])['cpu_util_percent']\n",
        "    .mean()\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "# Pivot → (machines × time) matrix\n",
        "print('  Building matrix...')\n",
        "cpu_pivot = (\n",
        "    cpu_agg\n",
        "    .pivot(index='machine_id', columns='time_bin', values='cpu_util_percent')\n",
        "    .ffill(axis=1)\n",
        "    .fillna(0)\n",
        "    .reindex(columns=range(N_BUCKETS), fill_value=0)\n",
        ")\n",
        "\n",
        "cpu_matrix      = cpu_pivot.values.astype(np.float32)\n",
        "top_100_machines = list(cpu_pivot.index)\n",
        "\n",
        "print(f'\\n  Matrix shape     : {cpu_matrix.shape}  (machines × time_steps)')\n",
        "print(f'  Non-zero entries : {(cpu_matrix > 0).sum():,} / {cpu_matrix.size:,}'\n",
        "      f'  ({100*(cpu_matrix > 0).mean():.1f}%)')\n",
        "print('\\nStep 2 Complete ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cell7_alibaba"
      },
      "source": [
        "# ============================================================\n",
        "# CELL 7: Preprocessing Step 3 — Per-machine Min-Max Scale\n",
        "# Alibaba CPU typically centered ~30-40%\n",
        "# ============================================================\n",
        "\n",
        "print('=== PREPROCESSING STEP 3: Scale ===\\n')\n",
        "\n",
        "cpu_scaled = np.zeros_like(cpu_matrix)\n",
        "\n",
        "for i in range(cpu_matrix.shape[0]):\n",
        "    row = cpu_matrix[i]\n",
        "    mn  = row.min()\n",
        "    mx  = row.max()\n",
        "    if mx - mn > 1e-10:\n",
        "        cpu_scaled[i] = (row - mn) / (mx - mn)\n",
        "    else:\n",
        "        cpu_scaled[i] = row\n",
        "\n",
        "# Remove machines with all zeros\n",
        "valid_mask = cpu_scaled.max(axis=1) > 0.01\n",
        "cpu_scaled = cpu_scaled[valid_mask]\n",
        "print(f'  Valid machines (non-zero) : {cpu_scaled.shape[0]}')\n",
        "\n",
        "cpu_nz = cpu_scaled[cpu_scaled > 0]\n",
        "print(f'  CPU mean (nonzero) : {cpu_nz.mean():.4f}')\n",
        "print(f'  CPU std            : {cpu_nz.std():.4f}')\n",
        "print(f'  CPU min            : {cpu_scaled.min():.4f}')\n",
        "print(f'  CPU max            : {cpu_scaled.max():.4f}')\n",
        "\n",
        "under = (cpu_nz < 0.20).mean() * 100\n",
        "over  = (cpu_nz > 0.80).mean() * 100\n",
        "norm  = 100 - under - over\n",
        "print(f'\\n  Under-utilized (<20%) : {under:.1f}%')\n",
        "print(f'  Normal (20%-80%)      : {norm:.1f}%')\n",
        "print(f'  Over-utilized  (>80%) : {over:.1f}%')\n",
        "print('\\nStep 3 Complete ✓')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
