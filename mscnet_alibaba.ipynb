        "ax.legend(fontsize=8)\n",
        "ax.grid(True, alpha=0.3)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('alibaba_preprocessing_results.png', dpi=150, bbox_inches='tight')\n",
        "plt.show()\n",
        "print('Saved: alibaba_preprocessing_results.png')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
