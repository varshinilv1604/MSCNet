        "    colors=['#FF9800', '#4CAF50', '#F44336'],\n",
        "    autopct='%1.1f%%', startangle=90\n",
        ")\n",
        "ax.set_title('Provisioning Status\\n(Alibaba cluster)')\n",
        "\n",
        "# Plot 4: Time series 3 machines\n",
        "ax = axes[1, 0]\n",
        "colors_ts = ['#B34700', '#8B0000', '#4A235A']\n",
        "for i, c in enumerate(colors_ts):\n",
        "    ax.plot(cpu_scaled[i, :288], color=c, lw=0.9, alpha=0.9, label=f'Machine {i+1}')\n",
        "ax.set_title('CPU Time Series\\n(3 sample machines, first 2 days)')\n",
        "ax.set_xlabel('Time Step (10-min)')\n",
        "ax.set_ylabel('CPU Utilization (scaled)')\n",
        "ax.legend(fontsize=8)\n",
        "ax.grid(True, alpha=0.3)\n",
        "\n",
        "# Plot 5: Heatmap\n",
        "ax = axes[1, 1]\n",
        "im = ax.imshow(cpu_scaled[:, ::6], aspect='auto', cmap='YlOrRd', vmin=0, vmax=0.8)\n",
        "ax.set_title('All 100 Machines Heatmap\\n(1-hour buckets)')\n",
        "ax.set_xlabel('Time (1-hour buckets)')\n",
        "ax.set_ylabel('Machine Index')\n",
        "plt.colorbar(im, ax=ax, fraction=0.03)\n",
        "\n",
        "# Plot 6: Autocorrelation\n",
        "ax = axes[1, 2]\n",
        "series_0 = cpu_scaled[0]\n",
        "lag_max  = min(300, len(series_0) - 1)\n",
        "autocorr = [\n",
        "    np.corrcoef(series_0[:-lag], series_0[lag:])[0, 1] if lag > 0 else 1.0\n",
        "    for lag in range(lag_max)\n",
        "]\n",
        "ax.plot(autocorr, color='#FF6B35', lw=1.5)\n",
        "ax.axvline(144, color='red', linestyle='--', lw=1, label='Daily period (144 steps)')\n",
        "ax.axhline(0,   color='black', linestyle='-', lw=0.5)\n",
