      "source": [
        "# ============================================================\n",
        "# CELL 17: Evaluation — H=24 (Review 2 horizon)\n",
        "# ============================================================\n",
        "\n",
        "def evaluate(model, te_dl):\n",
        "    model.load_state_dict(torch.load('best_mscnet_alibaba.pt'))\n",
        "    model.eval()\n",
        "    preds, trues = [], []\n",
        "    with torch.no_grad():\n",
        "        for xb, yb in te_dl:\n",
        "            pred = model(xb.to(device)).cpu().numpy()\n",
        "            preds.append(pred)\n",
        "            trues.append(yb.numpy())\n",
        "    preds = np.concatenate(preds).flatten()\n",
        "    trues = np.concatenate(trues).flatten()\n",
        "    mse  = mean_squared_error(trues, preds)\n",
        "    mae  = mean_absolute_error(trues, preds)\n",
        "    rmse = np.sqrt(mse)\n",
        "    return {'MSE': mse, 'MAE': mae, 'RMSE': rmse, 'preds': preds, 'trues': trues}\n",
        "\n",
        "res_h24 = evaluate(model, te_dl)\n",
        "print('=== Alibaba — H=24 Results ===')\n",
        "print(f'  MSE  : {res_h24[\"MSE\"]:.6f}')\n",
        "print(f'  MAE  : {res_h24[\"MAE\"]:.6f}')\n",
        "print(f'  RMSE : {res_h24[\"RMSE\"]:.6f}')\n"
print(f'  MAPE : {res_h24["MAPE"]:.6f}%')
