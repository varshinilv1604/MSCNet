      },
      "source": [
        "# ============================================================\n",
        "# CELL 8: Preprocessing Visualization\n",
        "# ============================================================\n",
        "\n",
        "fig, axes = plt.subplots(2, 3, figsize=(16, 9))\n",
        "fig.suptitle(\n",
        "    'Alibaba Cluster Trace 2018 — Data Preprocessing Results\\n'\n",
