        "# ============================================================\n",
        "# CELL 20: Multi-Horizon Training + Baselines\n",
        "# (Same extended workflow as mscnet_mini_project: LSTM / Transformer vs MSCNet)\n",
        "# ============================================================\n",
        "\n",
        "class LSTMBaseline(nn.Module):\n",
        "    def __init__(self, input_len=96, pred_len=24, hidden_dim=128, num_layers=2):\n",
        "        super().__init__()\n",
        "        self.pred_len = pred_len\n",
        "        self.revin = RevIN(num_features=1)\n",
        "        self.lstm = nn.LSTM(1, hidden_dim, num_layers, batch_first=True)\n",
        "        self.fc = nn.Linear(hidden_dim, pred_len)\n",
        "\n",
        "    def forward(self, x):\n",
        "        x = self.revin(x, 'norm')\n",
        "        out, _ = self.lstm(x)\n",
        "        out = self.fc(out[:, -1, :]).unsqueeze(-1)\n",
        "        return self.revin(out, 'denorm')\n",
        "\n",
        "\n",
        "class TransformerBaseline(nn.Module):\n",
        "    def __init__(self, input_len=96, pred_len=24, d_model=128, n_heads=8, N=2):\n",
        "        super().__init__()\n",
        "        self.pred_len = pred_len\n",
        "        self.revin = RevIN(1)\n",
        "        self.proj = nn.Linear(1, d_model)\n",
        "        self.pos_emb = nn.Parameter(torch.randn(1, input_len, d_model))\n",
        "        self.blocks = nn.ModuleList([\n",
        "            TransformerEncoderBlock(d_model, n_heads, d_model * 2, 0.2)\n",
        "            for _ in range(N)\n",
        "        ])\n",
        "        self.out = nn.Linear(d_model, pred_len)\n",
        "\n",
        "    def forward(self, x):\n",
        "        x = self.revin(x, 'norm')\n",
        "        x = self.proj(x) + self.pos_emb\n",
        "        for block in self.blocks:\n",
        "            x = block(x)\n",
        "        out = self.out(x.mean(dim=1)).unsqueeze(-1)\n",
        "        return self.revin(out, 'denorm')\n",
        "\n",
        "\n",
        "def train_and_evaluate(model_class, pred_len, run_name, epochs=15, series=None):\n",
        "    if series is None:\n",
        "        series = cpu_scaled[0]\n",
        "    tr_dl, val_dl, te_dl = get_loaders(\n",
        "        series, input_len=96, pred_len=pred_len, batch_size=32\n",
        "    )\n",
        "    model = model_class(input_len=96, pred_len=pred_len).to(device)\n",
        "    ckpt = f'best_{run_name}.pt'\n",
        "\n",
        "    opt = torch.optim.Adam(model.parameters(), lr=1e-4)\n",
        "    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n",
        "        opt, mode='min', factor=0.5, patience=3, verbose=False\n",
        "    )\n",
        "    criterion = nn.MSELoss()\n",
        "    best_val = float('inf')\n",
        "\n",
        "    for _epoch in range(epochs):\n",
        "        model.train()\n",
        "        for xb, yb in tr_dl:\n",
        "            xb, yb = xb.to(device), yb.to(device)\n",
        "            opt.zero_grad()\n",
        "            pred = model(xb)\n",
        "            loss = criterion(pred, yb)\n",
        "            loss.backward()\n",
        "            nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
        "            opt.step()\n",
        "\n",
        "        model.eval()\n",
        "        val_losses = []\n",
        "        with torch.no_grad():\n",
        "            for xb, yb in val_dl:\n",
        "                xb, yb = xb.to(device), yb.to(device)\n",
        "                val_losses.append(criterion(model(xb), yb).item())\n",
        "\n",
        "        val_loss = np.mean(val_losses)\n",
        "        scheduler.step(val_loss)\n",
        "        if val_loss < best_val:\n",
        "            best_val = val_loss\n",
        "            torch.save(model.state_dict(), ckpt)\n",
        "\n",
        "    model.load_state_dict(torch.load(ckpt, map_location=device))\n",
        "    model.eval()\n",
        "    preds, trues = [], []\n",
        "    with torch.no_grad():\n",
        "        for xb, yb in te_dl:\n",
        "            preds.append(model(xb.to(device)).cpu().numpy())\n",
        "            trues.append(yb.numpy())\n",
        "    preds = np.concatenate(preds).flatten()\n",
        "    trues = np.concatenate(trues).flatten()\n",
        "    mse = mean_squared_error(trues, preds)\n",
        "    mae = mean_absolute_error(trues, preds)\n",
        "    rmse = np.sqrt(mse)\n",
        "    return model, {\n",
        "        'MSE': mse, 'MAE': mae, 'RMSE': rmse,\n",
        "        'preds': preds, 'trues': trues,\n",
        "        'yp': preds, 'yt': trues,\n",
        "    }\n",
        "\n",
        "\n",
        "results = {}\n",
        "horizons = [24, 48, 72, 96]\n",
        "for h in horizons:\n",
        "    print(f'=== MSCNet | Alibaba | H={h} ===')\n",
        "    _, r = train_and_evaluate(MSCNet, h, f'mscnet_alibaba_h{h}', epochs=15)\n",
        "    results[f'MSCNet_H{h}'] = r\n",
        "    print(f'=== LSTM | Alibaba | H={h} ===')\n",
        "    _, r = train_and_evaluate(LSTMBaseline, h, f'lstm_alibaba_h{h}', epochs=10)\n",
        "    results[f'LSTM_H{h}'] = r\n",
        "    print(f'=== Transformer | Alibaba | H={h} ===')\n",
        "    _, r = train_and_evaluate(TransformerBaseline, h, f'trans_alibaba_h{h}', epochs=10)\n",
        "    results[f'Transformer_H{h}'] = r\n",
        "\n",
        "print('Multi-horizon + baselines complete ✓')"
      ],
      "execution_count": null,
      "outputs": []
